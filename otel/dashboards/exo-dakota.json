{
  "kind": "Dashboard",
  "metadata": {
    "name": "exo-dakota",
    "project": "ghost-lab"
  },
  "spec": {
    "display": {
      "name": "exo-dakota — Bluefin Node",
      "description": "System metrics and live journal logs from exo-dakota (192.168.1.247)"
    },
    "duration": "1h",
    "refreshInterval": "30s",
    "panels": {
      "statCPU": {
        "kind": "Panel",
        "spec": {
          "display": { "name": "CPU Load (1m)" },
          "plugin": {
            "kind": "StatChart",
            "spec": {
              "calculation": "last-number",
              "format": { "unit": "decimal", "decimalPlaces": 2 },
              "thresholds": { "steps": [{"value": 4}, {"value": 6}] }
            }
          },
          "queries": [{"kind": "TimeSeriesQuery","spec": {"plugin": {"kind": "PrometheusTimeSeriesQuery","spec": {"query": "system_cpu_load_average_1m{host_name=\"bluefin\"}"}}}}]
        }
      },
      "statMem": {
        "kind": "Panel",
        "spec": {
          "display": { "name": "Memory Used" },
          "plugin": {
            "kind": "StatChart",
            "spec": {
              "calculation": "last-number",
              "format": { "unit": "bytes" }
            }
          },
          "queries": [{"kind": "TimeSeriesQuery","spec": {"plugin": {"kind": "PrometheusTimeSeriesQuery","spec": {"query": "system_memory_usage_bytes{host_name=\"bluefin\", state=\"used\"}"}}}}]
        }
      },
      "statDisk": {
        "kind": "Panel",
        "spec": {
          "display": { "name": "Disk Used (/)" },
          "plugin": {
            "kind": "StatChart",
            "spec": {
              "calculation": "last-number",
              "format": { "unit": "bytes" }
            }
          },
          "queries": [{"kind": "TimeSeriesQuery","spec": {"plugin": {"kind": "PrometheusTimeSeriesQuery","spec": {"query": "system_filesystem_usage_bytes{host_name=\"bluefin\", mountpoint=\"/sysroot\", state=\"used\"}"}}}}]
        }
      },
      "statNetRx": {
        "kind": "Panel",
        "spec": {
          "display": { "name": "Network Rx (eno1)" },
          "plugin": {
            "kind": "StatChart",
            "spec": {
              "calculation": "last-number",
              "format": { "unit": "bytes" }
            }
          },
          "queries": [{"kind": "TimeSeriesQuery","spec": {"plugin": {"kind": "PrometheusTimeSeriesQuery","spec": {"query": "rate(system_network_io_bytes_total{host_name=\"bluefin\", device=\"eno1\", direction=\"receive\"}[5m])"}}}}]
        }
      },
      "cpuChart": {
        "kind": "Panel",
        "spec": {
          "display": { "name": "CPU Load Average" },
          "plugin": {
            "kind": "TimeSeriesChart",
            "spec": {
              "yAxis": { "format": { "unit": "decimal", "decimalPlaces": 2 } },
              "legend": { "position": "bottom" }
            }
          },
          "queries": [
            {"kind": "TimeSeriesQuery","spec": {"plugin": {"kind": "PrometheusTimeSeriesQuery","spec": {"seriesNameFormat": "1m","query": "system_cpu_load_average_1m{host_name=\"bluefin\"}"}}}},
            {"kind": "TimeSeriesQuery","spec": {"plugin": {"kind": "PrometheusTimeSeriesQuery","spec": {"seriesNameFormat": "5m","query": "system_cpu_load_average_5m{host_name=\"bluefin\"}"}}}},
            {"kind": "TimeSeriesQuery","spec": {"plugin": {"kind": "PrometheusTimeSeriesQuery","spec": {"seriesNameFormat": "15m","query": "system_cpu_load_average_15m{host_name=\"bluefin\"}"}}}}
          ]
        }
      },
      "memChart": {
        "kind": "Panel",
        "spec": {
          "display": { "name": "Memory — Used / Cached / Free" },
          "plugin": {
            "kind": "TimeSeriesChart",
            "spec": {
              "yAxis": { "format": { "unit": "bytes" } },
              "legend": { "position": "bottom" }
            }
          },
          "queries": [
            {"kind": "TimeSeriesQuery","spec": {"plugin": {"kind": "PrometheusTimeSeriesQuery","spec": {"seriesNameFormat": "{{state}}","query": "system_memory_usage_bytes{host_name=\"bluefin\", state=~\"used|cached|free\"}"}}}}
          ]
        }
      },
      "diskIOChart": {
        "kind": "Panel",
        "spec": {
          "display": { "name": "Disk I/O Rate" },
          "plugin": {
            "kind": "TimeSeriesChart",
            "spec": {
              "yAxis": { "format": { "unit": "bytes" } },
              "legend": { "position": "bottom" }
            }
          },
          "queries": [
            {"kind": "TimeSeriesQuery","spec": {"plugin": {"kind": "PrometheusTimeSeriesQuery","spec": {"seriesNameFormat": "{{device}} {{direction}}","query": "rate(system_disk_io_bytes_total{host_name=\"bluefin\", device!~\"loop.*\"}[5m])"}}}}
          ]
        }
      },
      "netIOChart": {
        "kind": "Panel",
        "spec": {
          "display": { "name": "Network I/O (eno1)" },
          "plugin": {
            "kind": "TimeSeriesChart",
            "spec": {
              "yAxis": { "format": { "unit": "bytes" } },
              "legend": { "position": "bottom" }
            }
          },
          "queries": [
            {"kind": "TimeSeriesQuery","spec": {"plugin": {"kind": "PrometheusTimeSeriesQuery","spec": {"seriesNameFormat": "{{direction}}","query": "rate(system_network_io_bytes_total{host_name=\"bluefin\", device=\"eno1\"}[5m])"}}}}
          ]
        }
      },
      "logsPanel": {
        "kind": "Panel",
        "spec": {
          "display": { "name": "System Logs (journal)" },
          "plugin": {
            "kind": "LogsTable",
            "spec": {
              "showTime": true,
              "enableDetails": true
            }
          },
          "queries": [
            {"kind": "TimeSeriesQuery","spec": {"plugin": {"kind": "LokiLogQuery","spec": {"query": "{host_name=\"bluefin\"}"}}}}
          ]
        }
      }
    },
    "layouts": [
      {
        "kind": "Grid",
        "spec": {
          "display": { "title": "At a Glance", "collapse": { "open": true } },
          "items": [
            {"x": 0,  "y": 0, "width": 6, "height": 4, "content": {"$ref": "#/spec/panels/statCPU"}},
            {"x": 6,  "y": 0, "width": 6, "height": 4, "content": {"$ref": "#/spec/panels/statMem"}},
            {"x": 12, "y": 0, "width": 6, "height": 4, "content": {"$ref": "#/spec/panels/statDisk"}},
            {"x": 18, "y": 0, "width": 6, "height": 4, "content": {"$ref": "#/spec/panels/statNetRx"}}
          ]
        }
      },
      {
        "kind": "Grid",
        "spec": {
          "display": { "title": "CPU & Memory", "collapse": { "open": true } },
          "items": [
            {"x": 0,  "y": 0, "width": 12, "height": 8, "content": {"$ref": "#/spec/panels/cpuChart"}},
            {"x": 12, "y": 0, "width": 12, "height": 8, "content": {"$ref": "#/spec/panels/memChart"}}
          ]
        }
      },
      {
        "kind": "Grid",
        "spec": {
          "display": { "title": "Disk & Network", "collapse": { "open": true } },
          "items": [
            {"x": 0,  "y": 0, "width": 12, "height": 8, "content": {"$ref": "#/spec/panels/diskIOChart"}},
            {"x": 12, "y": 0, "width": 12, "height": 8, "content": {"$ref": "#/spec/panels/netIOChart"}}
          ]
        }
      },
      {
        "kind": "Grid",
        "spec": {
          "display": { "title": "Journal Logs", "collapse": { "open": true } },
          "items": [
            {"x": 0, "y": 0, "width": 24, "height": 14, "content": {"$ref": "#/spec/panels/logsPanel"}}
          ]
        }
      }
    ]
  }
}
