{
  "kind": "Dashboard",
  "metadata": {
    "name": "ghost-lab",
    "project": "ghost-lab"
  },
  "spec": {
    "display": {
      "name": "Ghost Lab — Infrastructure Overview",
      "description": "CPU, memory, disk, network, VM count, container count for the ghost testlab node"
    },
    "duration": "1h",
    "refreshInterval": "30s",
    "panels": {
      "statCPU": {
        "kind": "Panel",
        "spec": {
          "display": { "name": "CPU Load (1m)" },
          "plugin": {
            "kind": "StatChart",
            "spec": {
              "calculation": "last-number",
              "format": { "unit": "decimal", "decimalPlaces": 2 },
              "thresholds": {
                "steps": [{"value": 8}, {"value": 16}]
              }
            }
          },
          "queries": [{"kind": "TimeSeriesQuery","spec": {"plugin": {"kind": "PrometheusTimeSeriesQuery","spec": {"query": "system_cpu_load_average_1m{host_name=\"ghost\"}"}}}}]
        }
      },
      "statMem": {
        "kind": "Panel",
        "spec": {
          "display": { "name": "Memory Used" },
          "plugin": {
            "kind": "StatChart",
            "spec": {
              "calculation": "last-number",
              "format": { "unit": "bytes" },
              "thresholds": {
                "steps": [{"value": 34359738368}, {"value": 51539607552}]
              }
            }
          },
          "queries": [{"kind": "TimeSeriesQuery","spec": {"plugin": {"kind": "PrometheusTimeSeriesQuery","spec": {"query": "system_memory_usage_bytes{host_name=\"ghost\", state=\"used\"}"}}}}]
        }
      },
      "statContainers": {
        "kind": "Panel",
        "spec": {
          "display": { "name": "Running Containers" },
          "plugin": {
            "kind": "StatChart",
            "spec": {
              "calculation": "last-number",
              "format": { "unit": "decimal", "decimalPlaces": 0 }
            }
          },
          "queries": [{"kind": "TimeSeriesQuery","spec": {"plugin": {"kind": "PrometheusTimeSeriesQuery","spec": {"query": "count(process_cpu_time_seconds_total{host_name=\"ghost\", process_executable_name=\"conmon\", state=\"user\"}) or vector(0)"}}}}]
        }
      },
      "statVMs": {
        "kind": "Panel",
        "spec": {
          "display": { "name": "Running VMs (QEMU)" },
          "plugin": {
            "kind": "StatChart",
            "spec": {
              "calculation": "last-number",
              "format": { "unit": "decimal", "decimalPlaces": 0 }
            }
          },
          "queries": [{"kind": "TimeSeriesQuery","spec": {"plugin": {"kind": "PrometheusTimeSeriesQuery","spec": {"query": "count(process_cpu_time_seconds_total{host_name=\"ghost\", process_executable_name=\"qemu-system-x86_64\", state=\"user\"}) or vector(0)"}}}}]
        }
      },
      "statDiskUsed": {
        "kind": "Panel",
        "spec": {
          "display": { "name": "Disk Used (/)" },
          "plugin": {
            "kind": "StatChart",
            "spec": {
              "calculation": "last-number",
              "format": { "unit": "bytes" }
            }
          },
          "queries": [{"kind": "TimeSeriesQuery","spec": {"plugin": {"kind": "PrometheusTimeSeriesQuery","spec": {"query": "system_filesystem_usage_bytes{host_name=\"ghost\", mountpoint=\"/sysroot\", state=\"used\"}"}}}}]
        }
      },
      "statNetRx": {
        "kind": "Panel",
        "spec": {
          "display": { "name": "Network Rx (eno1)" },
          "plugin": {
            "kind": "StatChart",
            "spec": {
              "calculation": "last-number",
              "format": { "unit": "bytes" }
            }
          },
          "queries": [{"kind": "TimeSeriesQuery","spec": {"plugin": {"kind": "PrometheusTimeSeriesQuery","spec": {"query": "rate(system_network_io_bytes_total{host_name=\"ghost\", device=\"eno1\", direction=\"receive\"}[5m])"}}}}]
        }
      },
      "cpuLoadChart": {
        "kind": "Panel",
        "spec": {
          "display": { "name": "CPU Load Average" },
          "plugin": {
            "kind": "TimeSeriesChart",
            "spec": {
              "yAxis": { "format": { "unit": "decimal", "decimalPlaces": 2 } },
              "legend": { "position": "bottom" }
            }
          },
          "queries": [
            {"kind": "TimeSeriesQuery","spec": {"plugin": {"kind": "PrometheusTimeSeriesQuery","spec": {"seriesNameFormat": "1m","query": "system_cpu_load_average_1m{host_name=\"ghost\"}"}}}},
            {"kind": "TimeSeriesQuery","spec": {"plugin": {"kind": "PrometheusTimeSeriesQuery","spec": {"seriesNameFormat": "5m","query": "system_cpu_load_average_5m{host_name=\"ghost\"}"}}}},
            {"kind": "TimeSeriesQuery","spec": {"plugin": {"kind": "PrometheusTimeSeriesQuery","spec": {"seriesNameFormat": "15m","query": "system_cpu_load_average_15m{host_name=\"ghost\"}"}}}}
          ]
        }
      },
      "memChart": {
        "kind": "Panel",
        "spec": {
          "display": { "name": "Memory Usage" },
          "plugin": {
            "kind": "TimeSeriesChart",
            "spec": {
              "yAxis": { "format": { "unit": "bytes" } },
              "legend": { "position": "bottom" }
            }
          },
          "queries": [
            {"kind": "TimeSeriesQuery","spec": {"plugin": {"kind": "PrometheusTimeSeriesQuery","spec": {"seriesNameFormat": "{{state}}","query": "system_memory_usage_bytes{host_name=\"ghost\", state=~\"used|cached|free\"}"}}}},
            {"kind": "TimeSeriesQuery","spec": {"plugin": {"kind": "PrometheusTimeSeriesQuery","spec": {"seriesNameFormat": "{{state}}","query": "system_memory_usage_bytes{host_name=\"ghost\", state=~\"used|cached|free\"}"}}}}
          ]
        }
      },
      "diskIOChart": {
        "kind": "Panel",
        "spec": {
          "display": { "name": "Disk I/O Rate" },
          "plugin": {
            "kind": "TimeSeriesChart",
            "spec": {
              "yAxis": { "format": { "unit": "bytes" } },
              "legend": { "position": "bottom" }
            }
          },
          "queries": [
            {"kind": "TimeSeriesQuery","spec": {"plugin": {"kind": "PrometheusTimeSeriesQuery","spec": {"seriesNameFormat": "{{device}} {{direction}}","query": "rate(system_disk_io_bytes_total{host_name=\"ghost\", device!~\"loop.*|sda[0-9]\"}[5m])"}}}}
          ]
        }
      },
      "netIOChart": {
        "kind": "Panel",
        "spec": {
          "display": { "name": "Network I/O Rate (eno1)" },
          "plugin": {
            "kind": "TimeSeriesChart",
            "spec": {
              "yAxis": { "format": { "unit": "bytes" } },
              "legend": { "position": "bottom" }
            }
          },
          "queries": [
            {"kind": "TimeSeriesQuery","spec": {"plugin": {"kind": "PrometheusTimeSeriesQuery","spec": {"seriesNameFormat": "{{direction}}","query": "rate(system_network_io_bytes_total{host_name=\"ghost\", device=\"eno1\"}[5m])"}}}}
          ]
        }
      },
      "containerHistoryChart": {
        "kind": "Panel",
        "spec": {
          "display": { "name": "Container Count Over Time" },
          "plugin": {
            "kind": "TimeSeriesChart",
            "spec": {
              "yAxis": { "format": { "unit": "decimal", "decimalPlaces": 0 } },
              "legend": { "position": "bottom" }
            }
          },
          "queries": [
            {"kind": "TimeSeriesQuery","spec": {"plugin": {"kind": "PrometheusTimeSeriesQuery","spec": {"seriesNameFormat": "containers","query": "count(process_cpu_time_seconds_total{host_name=\"ghost\", process_executable_name=\"conmon\", state=\"user\"}) or vector(0)"}}}},
            {"kind": "TimeSeriesQuery","spec": {"plugin": {"kind": "PrometheusTimeSeriesQuery","spec": {"seriesNameFormat": "VMs","query": "count(process_cpu_time_seconds_total{host_name=\"ghost\", process_executable_name=\"qemu-system-x86_64\", state=\"user\"}) or vector(0)"}}}}
          ]
        }
      },
      "processMemChart": {
        "kind": "Panel",
        "spec": {
          "display": { "name": "Container Memory Usage" },
          "plugin": {
            "kind": "TimeSeriesChart",
            "spec": {
              "yAxis": { "format": { "unit": "bytes" } },
              "legend": { "position": "bottom" }
            }
          },
          "queries": [
            {"kind": "TimeSeriesQuery","spec": {"plugin": {"kind": "PrometheusTimeSeriesQuery","spec": {"seriesNameFormat": "{{process_executable_name}} ({{process_pid}})","query": "process_memory_usage_bytes{host_name=\"ghost\", process_executable_name=~\"conmon|podman\"}"}}}}
          ]
        }
      }
    },
    "layouts": [
      {
        "kind": "Grid",
        "spec": {
          "display": { "title": "At a Glance", "collapse": { "open": true } },
          "items": [
            {"x": 0, "y": 0, "width": 4, "height": 4, "content": {"$ref": "#/spec/panels/statCPU"}},
            {"x": 4, "y": 0, "width": 4, "height": 4, "content": {"$ref": "#/spec/panels/statMem"}},
            {"x": 8, "y": 0, "width": 4, "height": 4, "content": {"$ref": "#/spec/panels/statContainers"}},
            {"x": 12, "y": 0, "width": 4, "height": 4, "content": {"$ref": "#/spec/panels/statVMs"}},
            {"x": 16, "y": 0, "width": 4, "height": 4, "content": {"$ref": "#/spec/panels/statDiskUsed"}},
            {"x": 20, "y": 0, "width": 4, "height": 4, "content": {"$ref": "#/spec/panels/statNetRx"}}
          ]
        }
      },
      {
        "kind": "Grid",
        "spec": {
          "display": { "title": "CPU & Memory", "collapse": { "open": true } },
          "items": [
            {"x": 0, "y": 0, "width": 12, "height": 8, "content": {"$ref": "#/spec/panels/cpuLoadChart"}},
            {"x": 12, "y": 0, "width": 12, "height": 8, "content": {"$ref": "#/spec/panels/memChart"}}
          ]
        }
      },
      {
        "kind": "Grid",
        "spec": {
          "display": { "title": "Disk & Network", "collapse": { "open": true } },
          "items": [
            {"x": 0, "y": 0, "width": 12, "height": 8, "content": {"$ref": "#/spec/panels/diskIOChart"}},
            {"x": 12, "y": 0, "width": 12, "height": 8, "content": {"$ref": "#/spec/panels/netIOChart"}}
          ]
        }
      },
      {
        "kind": "Grid",
        "spec": {
          "display": { "title": "VMs & Containers", "collapse": { "open": true } },
          "items": [
            {"x": 0, "y": 0, "width": 12, "height": 8, "content": {"$ref": "#/spec/panels/containerHistoryChart"}},
            {"x": 12, "y": 0, "width": 12, "height": 8, "content": {"$ref": "#/spec/panels/processMemChart"}}
          ]
        }
      }
    ]
  }
}
